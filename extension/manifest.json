{
  "manifest_version": 3,
  "name": "Polycast — Video Subtitle Word Saver",
  "version": "1.1.0",
  "description": "Click words in video subtitles to look them up and save to your Polycast dictionary. Works on YouTube, Netflix, and any site with a video player.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://*.netflix.com/*",
    "http://localhost:3001/*",
    "https://polycast-sequel.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/shared.js", "content/youtube.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.netflix.com/*"],
      "js": ["content/shared.js", "content/netflix.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://*.youtube.com/*", "https://*.netflix.com/*"],
      "js": ["content/shared.js", "content/generic.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
